{
  "name": "vite-plugins-mcp",
  "version": "0.1.0",
  "description": "MCP server for @hilosiva vite plugins",
  "license": "MIT",
  "author": "Shibata Hironori",
  "keywords": [
    "Vite",
    "MCP",
    "vite-plugins"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/hilosiva/vite-plugins.git",
    "directory": "packages/vite-plugins-mcp"
  },
  "bugs": "https://github.com/hilosiva/vite-plugins/issues",
  "homepage": "https://github.com/hilosiva/vite-plugins",
  "bin": {
    "vite-plugins-mcp": "./dist/index.mjs"
  },
  "scripts": {
    "prebuild": "node -e \"require('fs').rmSync('./dist', {recursive:true,force:true})\"",
    "build": "tsup-node",
    "dev": "tsup-node --watch"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "provenance": false,
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^22.2.0",
    "tsup": "^8.2.4",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  }
}
